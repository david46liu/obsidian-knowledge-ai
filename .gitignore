node_modules/
dist/
build/
*.log
.DS_Store
.vscode/
.idea/
.env
.env.local
coverage/
.vitest-cache/
.worktrees/

# Build artifacts — generated by `npm run build`, never committed.
main.js
extractor.worker.js
embedding.worker.js

# Vendored binaries — copied at build time from node_modules into project root
# for deploy.mjs to pick up. Not committed; release workflow re-stages them.
ort-wasm.wasm
ort-wasm-simd.wasm

# Lockfile — intentionally not committed, see package.json#private (we expect
# downstream contributors to regenerate it).
package-lock.json

# Releases bundled by scripts/release.mjs.
releases/

# Test fixtures (large binary files; checked in only when test references them).
src/extraction/__tests__/fixtures/

# Internal development docs (specs, plans, design docs). Not for public consumption.
docs/superpowers/

# User-facing usage docs ARE committed:
!docs/USAGE.md
!docs/USAGE.zh-CN.md

# Local secrets — must never be committed.
docs/api keys.md
docs/api-keys.md
**/api-keys*.md
**/api_keys*.md
*.secret
*.secrets

# Local deploy config (per-developer vault paths).
scripts/.deploy-vaults.json
